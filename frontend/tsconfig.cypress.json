/* TypeScript configuration for Cypress tests */
/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./out-tsc/cypress",
    "types": ["cypress", "node"]
  },
  "include": [
    "cypress/**/*.ts",
    "src/**/*.d.ts"
  ]
}
